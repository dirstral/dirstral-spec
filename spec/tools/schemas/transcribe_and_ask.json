{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/transcribe_and_ask.json",
  "title": "dir2mcp.transcribe_and_ask",
  "description": "Ensure transcript exists for audio file, then answer a question with citations.",
  "definitions": {
    "Span": {
      "type": "object",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "lines" },
            "start_line": { "type": "integer" },
            "end_line": { "type": "integer" }
          },
          "required": ["kind", "start_line", "end_line"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "page" },
            "page": { "type": "integer" }
          },
          "required": ["kind", "page"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "time" },
            "start_ms": { "type": "integer" },
            "end_ms": { "type": "integer" }
          },
          "required": ["kind", "start_ms", "end_ms"]
        }
      ]
    },
    "Hit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chunk_id": { "type": "integer" },
        "rel_path": { "type": "string" },
        "doc_type": { "type": "string" },
        "rep_type": { "type": "string" },
        "score": { "type": "number" },
        "snippet": { "type": "string" },
        "span": { "$ref": "#/definitions/Span" }
      },
      "required": ["chunk_id", "rel_path", "score", "snippet", "span"]
    },
    "Citation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chunk_id": { "type": "integer" },
        "rel_path": { "type": "string" },
        "span": { "$ref": "#/definitions/Span" }
      },
      "required": ["chunk_id", "rel_path", "span"]
    }
  },
  "input": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rel_path": { "type": "string", "minLength": 1 },
      "question": { "type": "string", "minLength": 1 },
      "k": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 }
    },
    "required": ["rel_path", "question"]
  },
  "output": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "question": { "type": "string" },
      "answer": { "type": "string" },
      "citations": {
        "type": "array",
        "items": { "$ref": "#/definitions/Citation" }
      },
      "hits": { "type": "array", "items": { "$ref": "#/definitions/Hit" } },
      "indexing_complete": { "type": "boolean" },
      "transcript_provider": { "type": "string", "enum": ["mistral", "elevenlabs"] },
      "transcript_model": { "type": "string" },
      "transcribed": { "type": "boolean" },
      "transcribed_now": { "type": "boolean" }
    },
    "required": ["question", "answer", "citations", "hits", "indexing_complete", "transcript_provider", "transcript_model", "transcribed"]
  }
}
