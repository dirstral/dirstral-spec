{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/transcribe_and_ask.json",
  "title": "dir2mcp.transcribe_and_ask",
  "description": "Ensure transcript exists for audio file, then answer a question with citations.",
  "definitions": {
    "Span": { "$ref": "https://spec.dirstral.com/tools/schemas/common.json#/definitions/Span" },
    "Hit": { "$ref": "https://spec.dirstral.com/tools/schemas/common.json#/definitions/Hit" },
    "Citation": { "$ref": "https://spec.dirstral.com/tools/schemas/common.json#/definitions/Citation" }
  },
  "input": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rel_path": { "type": "string", "minLength": 1 },
      "question": { "type": "string", "minLength": 1 },
      "k": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 }
    },
    "required": ["rel_path", "question"]
  },
  "output": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "question": { "type": "string" },
      "answer": { "type": "string" },
      "citations": {
        "type": "array",
        "items": { "$ref": "#/definitions/Citation" }
      },
      "hits": { "type": "array", "items": { "$ref": "#/definitions/Hit" } },
      "indexing_complete": { "type": "boolean" },
      "stt_provider": { "type": "string", "enum": ["mistral", "elevenlabs"] },
      "transcript_model": { "type": "string" },
      "transcribed": { "type": "boolean" },
      "transcribed_now": { "type": "boolean" }
    },
    "required": ["question", "answer", "citations", "hits", "indexing_complete", "stt_provider", "transcript_model", "transcribed"]
  }
}
