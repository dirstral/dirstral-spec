{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/stats.json",
  "title": "dir2mcp_stats",
  "description": "Status/progress/health for indexing and models.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": { "type": "string" },
        "state_dir": { "type": "string" },
        "protocol_version": { "type": "string" },
        "doc_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "total_docs": { "type": "integer" },
        "doc_counts_available": {
          "type": "boolean",
          "description": "When false, doc_counts and total_docs are zero-valued and must not be interpreted as an empty corpus."
        },
        "indexing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "job_id": { "type": "string" },
            "running": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["incremental", "full"] },
            "scanned": { "type": "integer" },
            "indexed": { "type": "integer" },
            "skipped": { "type": "integer" },
            "deleted": { "type": "integer" },
            "representations": { "type": "integer" },
            "chunks_total": { "type": "integer" },
            "embedded_ok": { "type": "integer" },
            "errors": { "type": "integer" }
          },
          "required": ["job_id", "running", "mode", "scanned", "indexed", "skipped", "deleted", "representations", "chunks_total", "embedded_ok", "errors"]
        },
        "models": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "embed_text": { "type": "string" },
            "embed_code": { "type": "string" },
            "ocr": { "type": "string" },
            "stt_provider": { "type": "string", "description": "STT provider name; not a closed enum (any STT-capable provider per SPEC §8.2)." },
            "stt_model": { "type": "string" },
            "chat": { "type": "string" }
          },
          "required": ["embed_text", "embed_code", "ocr", "stt_provider", "stt_model", "chat"]
        },
        "recent_failures": {
          "type": "array",
          "description": "Optional. Up to recent_failures_limit (default 20) of the most-recent documents with status='error', newest first by mtime_unix. Implementations MAY omit when no failures are recorded; clients MUST treat omission as 'no recent failures', not as 'unsupported'.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "rel_path": { "type": "string" },
              "doc_type": { "type": "string" },
              "mtime_unix": { "type": "integer" },
              "error_message": {
                "type": "string",
                "description": "Short, single-line, length-capped (SHOULD cap at 512 bytes on a UTF-8 rune boundary) explanation of why this document failed ingest. Control characters MUST be stripped. Never contains secrets or raw file content."
              }
            },
            "required": ["rel_path", "doc_type", "mtime_unix", "error_message"]
          }
        }
      },
      "required": ["root", "state_dir", "protocol_version", "doc_counts", "total_docs", "doc_counts_available", "indexing", "models"]
    }
  }
}
