{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/annotate.json",
  "title": "dir2mcp_annotate",
  "description": "Structured extraction using provided JSON schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "rel_path": { "type": "string", "minLength": 1 },
    "schema_json": { "type": "object" },
    "index_flattened_text": { "type": "boolean", "default": true },
    "max_chars": { "type": "integer", "minimum": 200, "maximum": 200000, "default": 32000 }
  },
  "required": ["rel_path", "schema_json"],
  "definitions": {
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rel_path": { "type": "string" },
        "stored": { "type": "boolean" },
        "flattened_indexed": { "type": "boolean" },
        "annotation_json": { "type": "object" },
        "annotation_text_preview": { "type": "string" },
        "source_doc_type": { "type": "string" },
        "source_rep": { "type": "string" }
      },
      "required": ["rel_path", "stored", "flattened_indexed", "annotation_json"]
    }
  }
}
