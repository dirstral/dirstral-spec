{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/common.json",
  "title": "dir2mcp_common",
  "description": "Shared schema definitions used by multiple tool contract documents.",
  "definitions": {
    "Span": {
      "type": "object",
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": { "kind": { "const": "lines" }, "start_line": { "type": "integer" }, "end_line": { "type": "integer" } },
          "required": ["kind", "start_line", "end_line"]
        },
        {
          "additionalProperties": false,
          "properties": { "kind": { "const": "page" }, "page": { "type": "integer" } },
          "required": ["kind", "page"]
        },
        {
          "additionalProperties": false,
          "properties": { "kind": { "const": "time" }, "start_ms": { "type": "integer" }, "end_ms": { "type": "integer" } },
          "required": ["kind", "start_ms", "end_ms"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "region" },
            "start_page": { "type": "integer" },
            "end_page": { "type": "integer" },
            "bbox": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "page": { "type": "integer" },
                "l": { "type": "number" }, "t": { "type": "number" },
                "r": { "type": "number" }, "b": { "type": "number" },
                "coord_origin": { "enum": ["TOPLEFT", "BOTTOMLEFT"] }
              },
              "required": ["page", "l", "t", "r", "b", "coord_origin"]
            },
            "section": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["kind", "start_page", "end_page", "bbox"]
        },
        {
          "additionalProperties": false,
          "properties": { "kind": { "const": "document" } },
          "required": ["kind"]
        }
      ]
    },
    "Hit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rel_path": { "type": "string" },
        "doc_type": { "type": "string" },
        "rep": { "type": "string" },
        "chunk_id": { "type": "string" },
        "score": { "type": "number" },
        "text": { "type": "string" },
        "span": { "$ref": "#/definitions/Span" }
      },
      "required": ["rel_path", "doc_type", "rep", "chunk_id", "score", "text"]
    },
    "Citation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rel_path": { "type": "string" },
        "doc_type": { "type": "string" },
        "rep": { "type": "string" },
        "chunk_id": { "type": "string" },
        "span": { "$ref": "#/definitions/Span" },
        "score": { "type": "number" },
        "quote": { "type": "string" }
      },
      "required": ["rel_path", "doc_type", "rep", "chunk_id", "score"]
    }
  }
}
