{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/transcribe.json",
  "title": "dir2mcp.transcribe",
  "description": "Force transcription for an indexed audio document.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "rel_path": { "type": "string", "minLength": 1 },
    "language": { "type": "string" },
    "timestamps": { "type": "boolean", "default": true },
    "retranscribe": { "type": "boolean", "default": false }
  },
  "required": ["rel_path"],
  "definitions": {
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rel_path": { "type": "string" },
        "provider": { "type": "string", "enum": ["mistral", "elevenlabs"] },
        "model": { "type": "string" },
        "indexed": { "type": "boolean" },
        "transcribed": { "type": "boolean" },
        "transcribed_now": { "type": "boolean" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "start_ms": { "type": "integer" },
              "end_ms": { "type": "integer" },
              "text": { "type": "string" }
            },
            "required": ["start_ms", "end_ms", "text"]
          }
        }
      },
      "required": ["rel_path", "provider", "model", "indexed", "transcribed"]
    }
  }
}
