{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/transcribe.json",
  "title": "dir2mcp_transcribe",
  "description": "Force transcription for an indexed audio document.",
  "input": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rel_path": { "type": "string", "minLength": 1 },
      "language": { "type": "string" },
      "timestamps": { "type": "boolean", "default": true },
      "retranscribe": { "type": "boolean", "default": false }
    },
    "required": ["rel_path"]
  },
  "output": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rel_path": { "type": "string" },
      "stt_provider": { "type": "string", "description": "STT provider name; not a closed enum (any STT-capable provider per SPEC §8.2)." },
      "model": { "type": "string" },
      "indexed": { "type": "boolean" },
      "transcribed": { "type": "boolean" },
      "transcribed_now": { "type": "boolean" },
      "segments": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start_ms": { "type": "integer" },
            "end_ms": { "type": "integer" },
            "text": { "type": "string" }
          },
          "required": ["start_ms", "end_ms", "text"]
        }
      }
    },
    "required": ["rel_path", "stt_provider", "model", "indexed", "transcribed"]
  }
}
