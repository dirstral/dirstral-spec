{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spec.dirstral.com/tools/schemas/ask.json",
  "title": "dir2mcp.ask",
  "description": "Tool contract document containing nested input and output schemas for RAG answers with citations; can run search-only mode.",
  "definitions": {
    "Span": { "$ref": "https://spec.dirstral.com/tools/schemas/common.json#/definitions/Span" },
    "Hit": { "$ref": "https://spec.dirstral.com/tools/schemas/common.json#/definitions/Hit" },
    "Citation": { "$ref": "https://spec.dirstral.com/tools/schemas/common.json#/definitions/Citation" }
  },
  "input": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "question": { "type": "string", "minLength": 1 },
      "k": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 },
      "mode": { "type": "string", "enum": ["answer", "search_only"], "default": "answer" },
      "index": { "type": "string", "enum": ["auto", "text", "code", "both"], "default": "auto" },
      "path_prefix": { "type": "string" },
      "file_glob": { "type": "string" },
      "doc_types": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["question"]
  },
  "output": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "question": { "type": "string" },
      "answer": { "type": "string" },
      "citations": {
        "type": "array",
        "items": { "$ref": "#/definitions/Citation" }
      },
      "hits": { "type": "array", "items": { "$ref": "#/definitions/Hit" } },
      "indexing_complete": { "type": "boolean" }
    },
    "required": ["question", "answer", "citations", "hits", "indexing_complete"]
  }
}
